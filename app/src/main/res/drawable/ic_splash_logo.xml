    <path
        android:pathData="M24,16 L72,16 L84,28 L84,92 L24,92 Z"
        android:fillColor="#FFFFFF"
        android:strokeColor="#BBDEFB"
        android:strokeWidth="2" />

    <!-- Folded corner -->
    <path
        android:pathData="M72,16 L72,28 L84,28 Z"
        android:fillColor="#BBDEFB" />

    <!-- Text lines -->
    <path
        android:pathData="M34,44 L74,44"
        android:strokeColor="#90CAF9"
        android:strokeWidth="3"
        android:strokeLineCap="round" />
    <path
        android:pathData="M34,54 L74,54"
        android:strokeColor="#90CAF9"
        android:strokeWidth="3"
        android:strokeLineCap="round" />
    <path
        android:pathData="M34,64 L60,64"
        android:strokeColor="#90CAF9"
        android:strokeWidth="3"
        android:strokeLineCap="round" />

    <!-- Pen / edit indicator -->
    <path
        android:pathData="M68,74 L80,62 L86,68 L74,80 Z"
        android:fillColor="#42A5F5" />
    <path
        android:pathData="M80,62 L84,58 L90,64 L86,68 Z"

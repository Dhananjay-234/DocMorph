<?xml version="1.0" encoding="utf-8"?>
<!--
    Paths exposed by DocMorphFileProvider.

    Only the app's private cache sub-directory for exports is exposed —
    nothing from external storage or the main files directory.
-->
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!--
        Matches FileProviderUtils.exportCacheDir():
        Context.cacheDir/exports/
    -->
    <cache-path
        name="exported_files"
        path="exports/" />
</paths>
